{
  "name": "overworld",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first visual control room for tmux-backed coding agents",
  "scripts": {
    "dev": "npm run dev:clean && concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:clean": "node ./kill-dev-ports.mjs 7600 7601",
    "dev:server": "OVERWORLD_API_PORT=7601 tsx watch src/server/index.ts",
    "dev:client": "vite --host 127.0.0.1 --port 7600",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/server/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "express": "^4.21.2",
    "fast-glob": "^3.3.3",
    "nanoid": "^5.1.6",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.3",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vite": "^6.2.1"
  }
}
